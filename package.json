{
  "name": "minamp",
  "version": "0.1.4",
  "description": "Lightweight cross-platform MP3 player",
  "author": "metalbabble.com",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac":   "electron-builder --mac",
    "build:win":   "electron-builder --win",
    "build:linux":     "electron-builder --linux --x64",
    "build:linux:arm": "electron-builder --linux --arm64",
    "build:linux:all": "electron-builder --linux --x64 --arm64",
    "build:all":       "electron-builder --mac --win --linux --x64 --arm64"
  },
  "build": {
    "appId": "com.minamp.app",
    "productName": "MinAmp",
    "icon": "icon.png",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "fileAssociations": [
      { "ext": "mp3",  "name": "Audio File",    "role": "Viewer" },
      { "ext": "flac", "name": "Audio File",    "role": "Viewer" },
      { "ext": "ogg",  "name": "Audio File",    "role": "Viewer" },
      { "ext": "wav",  "name": "Audio File",    "role": "Viewer" },
      { "ext": "m4a",  "name": "Audio File",    "role": "Viewer" },
      { "ext": "aac",  "name": "Audio File",    "role": "Viewer" },
      { "ext": "opus", "name": "Audio File",    "role": "Viewer" },
      { "ext": "wma",  "name": "Audio File",    "role": "Viewer" },
      { "ext": "m3u",  "name": "Playlist File", "role": "Viewer" },
      { "ext": "m3u8", "name": "Playlist File", "role": "Viewer" }
    ],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.music"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64", "arm64"] }],
      "category": "Audio"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "dependencies": {
    "music-metadata": "^11.12.3"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  }
}
